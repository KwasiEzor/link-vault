generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  links         Link[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Link {
  id              String   @id @default(cuid())
  url             String
  title           String
  description     String?
  image           String?
  category        String?  @default("general")
  status          String?  @default("active")
  
  // AI Suggestions (The "Back-end" of enrichment)
  aiSummary       String?
  aiCategory      String?
  enrichmentStatus String? @default("idle") // idle, pending, completed, failed
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  slug            String?  @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks          Click[]

  @@index([userId])
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  userAgent String?
  referrer  String?
  ip        String?
  country   String?

  @@index([linkId])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
